# Cloudflare Pages headers · defendablerouter.com
#
# We cracked the router · OpenWrt for AI agents · single-page surface
# all anchors live under /.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: SAMEORIGIN
  X-Robots-Tag: index, follow, max-snippet:-1, max-image-preview:large
  X-AI-Context: defendablerouter
  X-Defendable-Doctrine: validate-the-validator
  X-Defendable-Surface: agent-middleware
  X-Defendable-Energy: openwrt

/
  Cache-Control: public, max-age=300, s-maxage=300, stale-while-revalidate=86400
  Link: </llms.txt>; rel="alternate"; type="text/plain"; title="AI context manifest"

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Cache-Control: public, max-age=86400, s-maxage=86400
  Access-Control-Allow-Origin: *

/favicon.svg
  Cache-Control: public, max-age=86400, s-maxage=86400
  Access-Control-Allow-Origin: *
