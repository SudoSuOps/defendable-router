# DefendableRouter · env example · copy to .env and fill in
# Keys are never required to RUN the deterministic receipt spine.
# Kimi review will skip cleanly when MOONSHOT_API_KEY is absent.

# Model agents (optional · agents only · NOT used for deterministic hashing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
QWEN_API_KEY=

# Moonshot / Kimi review knobs
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_THINKING=disabled
# Optional: override request defaults. kimi-k2.6 enforces temperature=1; omit to use API default.
# MOONSHOT_TEMPERATURE=
# MOONSHOT_TIMEOUT=180

# StreetChat intake server
# ROUTER_RUNS_DIR=data/runs
# STREETCHAT_INTAKE_TOKEN=  # if set, /intake/streetchat requires Authorization: Bearer <token>

# Router provenance · stamped into receipts
ROUTER_HOST=smash
ROUTER_GPU=RTX 5090
ROUTER_CUDA=13.1
STREETLEDGER_BUCKET=streetledger
